# sum-the-yt configuration. Copy to `.env` and adjust. CLI flags override these.

# Load cookies from a browser to avoid YouTube rate limiting (HTTP 429).
# Values: chrome | safari | firefox | brave | edge (optionally chrome:ProfileName)
SUMYT_COOKIES_FROM_BROWSER=chrome

# Override the claude CLI model (leave blank to use the CLI default).
# e.g. claude-opus-4-8, claude-haiku-4-5
SUMYT_CLAUDE_MODEL=

# faster-whisper model size for the fallback path: tiny|base|small|medium|large-v3
SUMYT_WHISPER_MODEL=small

# Base directory for per-video artifact folders.
SUMYT_VIDEOS_DIR=videos

# Transcript char count above which map-reduce summarization is used.
SUMYT_MAX_CHARS=120000

# Set to 1/true to disable the Whisper fallback (fail if no subtitles).
SUMYT_NO_WHISPER=
